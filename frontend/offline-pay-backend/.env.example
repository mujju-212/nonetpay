# Environment Variables for Offline Pay Backend (DO NOT COMMIT .env FILE!)

# MongoDB Connection (REQUIRED)
# For development: use MongoDB Atlas free tier
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/offline_pay?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your-username:your-password@cluster0.xxxxx.mongodb.net/offline_pay?retryWrites=true&w=majority

# MongoDB Database Name (OPTIONAL - defaults to offline_pay)
MONGODB_DB_NAME=offline_pay

# JWT Secret Key (REQUIRED - CHANGE THIS!)
# Generate secure key with: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=your_super_secure_random_jwt_secret_key_change_this

# JWT Token Expiration (OPTIONAL - defaults to 7d)
JWT_EXPIRE=7d

# Server Port (OPTIONAL - Render assigns automatically)
# Render uses PORT env var automatically, fallback to 4000 for local dev
PORT=4000

# Node Environment (REQUIRED for production)
NODE_ENV=production

# Additional Settings for Production
# These are automatically handled by Render deployment

# For Render deployment, you only need to set:
# 1. MONGODB_URI (your MongoDB Atlas connection string)
# 2. JWT_SECRET (generate a secure random string)
# 3. NODE_ENV=production
